generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Emirate {
  ABU_DHABI
  DUBAI
  SHARJAH
  AJMAN
  UMM_AL_QUWAIN
  RAS_AL_KHAIMAH
  FUJAIRAH
}

enum Gender {
  MALE
  FEMALE
}

enum ClassMode {
  IN_PERSON
  ONLINE
  HYBRID
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

// ─────────────────────────────────────────────
// CORE USER MODELS
// ─────────────────────────────────────────────

model User {
  id          String    @id @db.Uuid  // No @default — Supabase Auth provides this UUID via trigger
  email       String    @unique
  emiratesId  String?   @unique
  name        String?
  nameAr      String?
  role        Role      @default(STUDENT)
  phone       String?
  gender      Gender?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  student     Student?
  teacher     Teacher?
  messages    Message[] // messages sent by this user in class sessions
}

model Teacher {
  userId         String   @id @db.Uuid
  user           User            @relation(fields: [userId], references: [id])
  classes        Class[]
  attendanceLogs AttendanceLog[]
}

model Student {
  userId         String   @id @db.Uuid
  user           User            @relation(fields: [userId], references: [id])
  currentJuz     Int             @default(0)  // 1–30, which juz they're currently memorizing
  enrollments    Enrollment[]
  attendanceLogs AttendanceLog[]
}

// ─────────────────────────────────────────────
// MOSQUE & SCHEDULING
// ─────────────────────────────────────────────

model Mosque {
  id        String   @id @default(uuid())
  nameAr    String
  nameEn    String
  emirate   Emirate
  address   String
  latitude  Float?   // for map display
  longitude Float?
  classes   Class[]
}

model Class {
  id        String    @id @default(uuid())
  title     String
  titleAr   String?
  mode      ClassMode @default(IN_PERSON)

  // Mosque — nullable because online-only classes have no physical location
  mosqueId  String?
  mosque    Mosque?   @relation(fields: [mosqueId], references: [id])

  teacherId String    @db.Uuid
  teacher   Teacher   @relation(fields: [teacherId], references: [userId])

  sessions    ClassSession[]
  enrollments Enrollment[]
}

model ClassSession {
  // One specific meeting of a class on one specific date
  id           String    @id @default(uuid())
  classId      String
  class        Class     @relation(fields: [classId], references: [id])
  date         DateTime  // the exact date this session occurs
  isCancelled  Boolean   @default(false)
  cancelReason String?

  // Video/voice room — generated by your provider (Daily.co, LiveKit, etc.)
  // null if session is in-person only and no virtual room was created
  roomId       String?   @unique
  // ↑ Unique because each session gets its own room, never shared

  attendance   AttendanceLog[]
  messages     Message[]       // text chat during this session
}

// ─────────────────────────────────────────────
// ENROLLMENT
// ─────────────────────────────────────────────

model Enrollment {
  id        String   @id @default(uuid())
  studentId String   @db.Uuid
  classId   String

  student   Student  @relation(fields: [studentId], references: [userId])
  class     Class    @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, classId])
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model AttendanceLog {
  id        String           @id @default(uuid())
  sessionId String
  studentId String           @db.Uuid
  teacherId String           @db.Uuid

  session   ClassSession     @relation(fields: [sessionId], references: [id])
  student   Student          @relation(fields: [studentId], references: [userId])
  teacher   Teacher          @relation(fields: [teacherId], references: [userId])

  status    AttendanceStatus @default(PRESENT)
  note      String?
  recordedAt DateTime        @default(now())

  @@unique([sessionId, studentId])
  // ↑ One attendance record per student per session — enforced at DB level
}

// ─────────────────────────────────────────────
// COMMUNICATION (text chat)
// ─────────────────────────────────────────────

model Message {
  id        String       @id @default(uuid())
  sessionId String
  senderId  String       @db.Uuid // User.id — both teachers and students can message

  session   ClassSession @relation(fields: [sessionId], references: [id])
  sender    User         @relation(fields: [senderId], references: [id])

  content   String
  createdAt DateTime     @default(now())
}
